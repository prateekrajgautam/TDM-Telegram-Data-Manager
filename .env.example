# Get these from https://my.telegram.org -> API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Random string used for session signing — change this in production
SECRET_KEY=change-me-in-production

# Host port to publish the web UI on
WEB_PORT=8000

# Host directory to mount as the default local download target.
# Can be any local path, or an already-mounted network share (NFS/SMB/etc)
# so TDM saves media directly to it.
DOWNLOAD_DIR=./downloads

# Number of simultaneous download jobs (single-worker by default)
MAX_CONCURRENT_DOWNLOADS=1

# Image tag to run/build, e.g. latest or a version like 0.1.0
TDM_VERSION=latest

TZ=UTC
